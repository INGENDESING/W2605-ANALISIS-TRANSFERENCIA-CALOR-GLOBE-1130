# Configuración de la Aplicación W2605
# Copiar este archivo a .env y ajustar los valores

# Modo de ejecución: development, production, testing
FLASK_ENV=development
FLASK_DEBUG=True

# Clave secreta para sesiones (cambiar en producción)
SECRET_KEY=tu-clave-secreta-aqui-cambiar-en-produccion

# Configuración del servidor
HOST=0.0.0.0
PORT=5000

# CORS - Orígenes permitidos (separados por coma)
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# Configuración de cálculos
DEFAULT_AREA_CONTACTO=13.0
DEFAULT_VELOCIDAD_AGUA=2.5
DEFAULT_TEMP_AGUA=65.0

# Límites de exportación
EXPORT_MAX_ROWS=10000
